# PostgreSQL — same DB as aitrace-java-backend
DATABASE_URL=postgresql://postgres:123456@localhost:5432/aitrace

# LLM judge (OpenAI-compatible endpoint)
JUDGE_API_BASE=YOURS
JUDGE_API_KEY=YOURS
JUDGE_MODEL=YOURS

# LLM call timeout in seconds (job marked failed if exceeded)
JUDGE_TIMEOUT_SECONDS=600

# Max concurrent jobs processed at once
WORKER_CONCURRENCY=4
